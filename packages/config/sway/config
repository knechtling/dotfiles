# ~/.config/sway/config
# Ported from ~/.local/src/dwl/config.def.h so it feels like the dwl setup.
# Sway's native i3-style tiling replaces dwl's master/stack.

### Variables
set $mod      Mod4
set $term     foot
set $menu     walker
set $browser  firefox
set $music    feishin
set $mail     thunderbird
set $filemanager     nautlilus

### Input -------------------------------------------------------------------
# German layout, caps:escape (matches dwl xkb_rules).
input "type:keyboard" {
    xkb_layout de
    xkb_model  pc105
    xkb_options caps:escape
    repeat_rate  25
    repeat_delay 600
}

# Trackpad (mirrors libinput settings from config.def.h).
input "type:touchpad" {
    tap              enabled
    drag             enabled
    drag_lock        enabled
    dwt              enabled            # disable-while-typing
    natural_scroll   disabled
    middle_emulation disabled
    click_method     button_areas
    scroll_method    two_finger
    accel_profile    adaptive
    pointer_accel    0
    tap_button_map   lrm
    events           enabled
}

### Focus / feel ------------------------------------------------------------
focus_follows_mouse yes
mouse_warping       container
workspace_auto_back_and_forth yes

### Appearance --------------------------------------------------------------
font pango:monospace 10

# Gaps + borders (dwl: gappx=10, borderpx=2, smartborders=1, smartgaps=0).
gaps inner 10
gaps outer 0
smart_gaps          off
smart_borders       on
default_border      pixel 2
default_floating_border pixel 2

# Colors (derived from dwl SchemeNorm/SchemeSel/SchemeUrg).
# class                 border    bg        text      indicator child_border
client.focused          #0066cc   #005577   #eeeeee   #0066cc   #0066cc
client.focused_inactive #444444   #222222   #bbbbbb   #444444   #444444
client.unfocused        #444444   #222222   #bbbbbb   #444444   #444444
client.urgent           #770000   #222222   #eeeeee   #770000   #770000
client.background       #000000

### Outputs -----------------------------------------------------------------
# dwl autostart used: wlr-randr --output DP-2 --mode 2560x1440@143.994995 --left-of DP-1
output DP-2 mode 2560x1440@143.994Hz position 0 0
output DP-1 position 2560 0
# Fallback wallpaper (setbg takes over at runtime if available).
output * bg "$HOME/.local/share/wallpapers/vjtkt501abr81.png" fill

### Window rules ------------------------------------------------------------
# Mirrors dwl's `rules` array: dialogs/utility windows float; Gimp example.
for_window [title="floating"]           floating enable
for_window [app_id="Gimp_EXAMPLE"]      floating enable
for_window [window_role="pop-up"]       floating enable
for_window [window_role="dialog"]       floating enable
for_window [window_type="dialog"]       floating enable

# Named scratchpads (see ~/.local/bin/sway-scratch for the toggle logic).
for_window [app_id="scratchpad"]  floating enable, move scratchpad, resize set 80 ppt 70 ppt
for_window [app_id="scratchnet"]  floating enable, move scratchpad, resize set 80 ppt 70 ppt
for_window [app_id="Bitwarden"]   floating enable, move scratchpad, resize set 80 ppt 70 ppt

### Keybindings =============================================================
# -- system / launchers --
bindsym $mod+Return            exec $term
bindsym $mod+d                 exec $menu
bindsym $mod+F1                exec j4-dmenu-desktop
bindsym $mod+c                 exec sh -c 'cliphist list | wmenu | cliphist decode | wl-copy'
bindsym $mod+BackSpace         exec sysact
bindsym Control_R              exec wlr-which-key

# -- scratchpads --
bindsym $mod+Shift+Return      exec ~/.local/bin/sway-scratch term
bindsym $mod+Shift+p           exec ~/.local/bin/sway-scratch bw
bindsym $mod+Shift+w           exec ~/.local/bin/sway-scratch net

# -- apps --
bindsym $mod+w                 exec $browser
bindsym $mod+z                 exec $music
bindsym $mod+e                 exec $mail
bindsym $mod+r                 exec $filemanager
bindsym $mod+n                 exec $term -e nvim -c WikiIndex
# bindsym $mod+i                 exec $term -e pkg-install
# bindsym $mod+Shift+r           exec $term -e pkg-remove
# bindsym $mod+Shift+h           exec $term -e htop
bindsym $mod+Shift+y           exec $term -e ytfzf -t
bindsym $mod+Shift+c           exec gtk-launch whatsapp-web

# -- dmenu helpers --
bindsym $mod+F3                exec displayselect
bindsym $mod+F4                exec $term -e pulsemixer
bindsym $mod+F7                exec dmenuunicode
bindsym $mod+Mod1+u            exec ~/.local/bin/dmenuhandler
bindsym $mod+Mod1+m            exec ~/.local/bin/dmenumountcifs
bindsym $mod+Mod1+w            exec ~/.local/bin/weblaunch
bindsym $mod+Mod1+p            exec ~/.local/bin/maimpick-wl
bindsym $mod+Mod1+r            exec ~/.local/bin/dmenurecord

# -- screenshots --
bindsym $mod+Print             exec ~/.local/bin/screenshot.sh
bindsym $mod+Shift+Print       exec ~/.local/bin/screenshot.sh
bindsym $mod+s                 exec ~/.local/bin/screenshot.sh
bindsym $mod+F8                exec ~/.local/bin/screenshot.sh
bindsym $mod+Shift+F8          exec ~/.local/bin/screenshot.sh

# -- audio / brightness via swayosd-client (identical to dwl bindings) --
bindsym XF86AudioMute          exec swayosd-client --output-volume mute-toggle
bindsym XF86AudioMicMute       exec swayosd-client --input-volume  mute-toggle
bindsym XF86AudioRaiseVolume   exec swayosd-client --output-volume raise
bindsym XF86AudioLowerVolume   exec swayosd-client --output-volume lower
bindsym XF86AudioPrev          exec swayosd-client --playerctl prev
bindsym XF86AudioNext          exec swayosd-client --playerctl next
bindsym XF86AudioPause         exec swayosd-client --playerctl play-pause
bindsym XF86AudioPlay          exec swayosd-client --playerctl play-pause
bindsym XF86AudioStop          exec swayosd-client --playerctl stop
bindsym XF86MonBrightnessUp    exec swayosd-client --brightness raise
bindsym XF86MonBrightnessDown  exec swayosd-client --brightness lower

# Keyboard shortcuts for volume/mute.
bindsym $mod+plus              exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym $mod+Shift+asterisk    exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 15%+
bindsym $mod+Shift+m           exec wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle

# -- MX Mechanical Mini F-row (Solaar-diverted to XF86 Launch*/Search) --
bindsym XF86Launch1            exec dmenuunicode
bindsym XF86Launch0            exec screenshot.sh -s
bindsym XF86Launch2            exec dmenurecord
bindsym XF86Search             exec $menu

# -- window management --
bindsym $mod+q                 kill
bindsym $mod+Shift+f           floating toggle
bindsym $mod+k                 focus right
bindsym $mod+j                 focus left
bindsym $mod+h                 resize shrink width  5 ppt
bindsym $mod+l                 resize grow   width  5 ppt
bindsym $mod+Shift+j           move down
bindsym $mod+Shift+k           move up
bindsym $mod+Shift+l           move right
bindsym $mod+Shift+h        move left

bindsym $mod+Tab               workspace back_and_forth
bindsym $mod+b                 bar mode toggle
bindsym $mod+space             layout toggle split

# Layout keys (loose mapping of dwl's tile/floating/monocle).
bindsym $mod+t                 layout toggle split
bindsym $mod+f                 fullscreen toggle
bindsym $mod+m                 layout tabbed

# Toggle gaps on/off (dwl: togglegaps).
bindsym $mod+g                 exec swaymsg gaps inner all toggle 10

# -- workspaces 1..9 --
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

# German shifted digits, matching dwl's TAGKEYS.
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

# -- multi-monitor --
bindsym $mod+comma             focus output left
bindsym $mod+period            focus output right
bindsym $mod+Shift+comma       move container to output left
bindsym $mod+Shift+period      move container to output right

# -- mouse (mirrors dwl buttons: mod+drag = move, mod+right-drag = resize) --
# floating_modifier covers Mod+Btn1 = move, Mod+Btn3 = resize for floating windows.
floating_modifier $mod normal
# Middle-click on any window toggles floating (dwl: MODKEY+BTN_MIDDLE togglefloating).
bindsym --whole-window $mod+button2 floating toggle

# -- quit sway --
bindsym $mod+Shift+q           exit
bindsym Control+Mod1+BackSpace exit

# -- resize mode (optional, useful without master/stack fiddling) --
mode "resize" {
    bindsym h resize shrink width  5 ppt
    bindsym l resize grow   width  5 ppt
    bindsym k resize shrink height 5 ppt
    bindsym j resize grow   height 5 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+x mode "resize"

### Bar ---------------------------------------------------------------------
bar {
    swaybar_command waybar
}

### Autostart ---------------------------------------------------------------

# Notification daemon.
exec_always swaync

# Clipboard history.
exec_always sh -c 'pgrep -f "wl-paste --watch cliphist store" >/dev/null || wl-paste --watch cliphist store'

# Idle / lock.
exec_always sh -c 'pgrep -x swayidle >/dev/null || swayidle -w -C "$HOME/.config/swayidle/config"'

# Foot server for footclient.
exec_always foot --server

# swayosd-server for OSD popups.
exec_always swayosd-server

# Arch-update tray icon.
exec_always arch-update --tray

# For better walker startup times
exec_always walker --gapplication-service

exec_always nm-applet
exec_always blueman-applet

### Drop-ins ----------------------------------------------------------------
include ~/.config/sway/config.d/*
