#!/bin/sh

# Emoji picker script compatible with both X11 and Wayland
# Dependencies:
# - wmenu (Wayland) or dmenu (X11)
# - wtype (Wayland typing) or xdotool (X11 typing)
# - wl-copy (Wayland clipboard) or xclip (X11 clipboard)
# - notify-send

notify() {
  msg=$1
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "dmenuunicode" "$msg"
  else
    printf 'dmenuunicode: %s\n' "$msg" >&2
  fi
}

require_tool() {
  tool=$1
  shift
  msg=$*
  [ -n "$msg" ] || msg="Missing required tool: $tool"
  if ! command -v "$tool" >/dev/null 2>&1; then
    notify "$msg"
    return 1
  fi
  return 0
}

# Choose display protocol
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  require_tool wmenu "wmenu is required to display the emoji list" || exit 1
  require_tool wtype "wtype is required to type emojis" || exit 1
  require_tool wl-copy "wl-copy is required to copy emojis" || exit 1
  menu_cmd="wmenu -i -l 30"
  type_cmd="wtype"
  copy_cmd="wl-copy"
else
  require_tool dmenu "dmenu is required to display the emoji list" || exit 1
  require_tool xdotool "xdotool is required to type emojis" || exit 1
  require_tool xclip "xclip is required to copy emojis" || exit 1
  menu_cmd="dmenu -i -l 30"
  type_cmd="xdotool type"
  copy_cmd="xclip -selection clipboard"
fi

# Get user selection from emoji list
chosen=$(cut -d ';' -f1 ~/.local/share/larbs/chars/* | eval "$menu_cmd" | sed "s/ .*//")

# Exit if nothing selected
[ -z "$chosen" ] && exit

# Type or copy based on argument
if [ -n "$1" ]; then
  eval "$type_cmd \"$chosen\""
else
  printf "%s" "$chosen" | $copy_cmd
  notify "'$chosen' copied to clipboard."
fi
