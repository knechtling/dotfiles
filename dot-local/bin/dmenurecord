#!/bin/sh

# dwl may close stdin for keybind commands; reopen so slurp/wmenu still work.
if [ ! -e /proc/self/fd/0 ]; then
  exec </dev/null
fi

WMENU="wmenu -i"
recording_dir="${VIDEO_RECORDINGS:-$HOME/Videos/screencasts}"
mkdir -p "$recording_dir"
pidfile="/tmp/recordingpid"
iconfile="/tmp/recordingicon"
statusbar="${STATUSBAR:-dwmblocks}"
fallback_notice_shown=0

notify() {
  msg=$1
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Screen recorder" "$msg"
  else
    printf 'dmenurecord: %s\n' "$msg" >&2
  fi
}

updateicon() {
  echo "$1" >"$iconfile"
  pkill -RTMIN+9 "$statusbar" >/dev/null 2>&1
}

cleanup_record_state() {
  [ ! -f "$pidfile" ] && return
  recpid=$(cat "$pidfile")
  if kill -0 "$recpid" >/dev/null 2>&1; then
    return
  fi
  rm -f "$pidfile"
  updateicon ""
}

killrecording() {
  [ ! -f "$pidfile" ] && return
  recpid=$(cat "$pidfile")
  kill -TERM -- "-$recpid" >/dev/null 2>&1 || kill -TERM "$recpid" >/dev/null 2>&1
  rm -f "$pidfile"
  updateicon ""
}

start_recording() {
  icon="$1"
  shift
  setsid "$@" >/dev/null 2>&1 &
  recpid=$!
  sleep 0.2
  if ! kill -0 "$recpid" >/dev/null 2>&1; then
    return 1
  fi
  echo "$recpid" >"$pidfile"
  updateicon "$icon"
  return 0
}

try_start_wf_recorder() {
  icon="$1"
  shift
  if start_recording "$icon" wf-recorder -a "$@"; then
    return 0
  fi
  if [ $fallback_notice_shown -eq 0 ]; then
    notify "Falling back to video-only recording (audio backend unavailable?)"
    fallback_notice_shown=1
  fi
  start_recording "⏺️" wf-recorder "$@"
}

screencast() {
  stamp="$(date '+%y%m%d-%H%M-%S')"
  outfile="$recording_dir/screencast-$stamp.mkv"
  try_start_wf_recorder "⏺️🎙️" -f "$outfile" || notify "Failed to start screencast"
}

video_selection() {
  geom=$(slurp) || return
  [ -z "$geom" ] && return
  stamp="$(date '+%y%m%d-%H%M-%S')"
  outfile="$recording_dir/box-$stamp.mkv"
  try_start_wf_recorder "⏺️" -g "$geom" -f "$outfile" || notify "Failed to start region recording"
}

audio_only() {
  stamp="$(date '+%y%m%d-%H%M-%S')"
  outfile="$recording_dir/audio-$stamp.flac"
  start_recording "🎙️" ffmpeg -f pulse -i default -c:a flac "$outfile" || notify "Audio recording failed"
}

webcam() {
  stamp="$(date '+%y%m%d-%H%M-%S')"
  outfile="$recording_dir/webcam-$stamp.mkv"
  start_recording "🎥" ffmpeg -f v4l2 -video_size 640x480 -i /dev/video0 "$outfile" || notify "Webcam recording failed"
}

webcam_hq() {
  stamp="$(date '+%y%m%d-%H%M-%S')"
  outfile="$recording_dir/webcam-hq-$stamp.mkv"
  start_recording "🎥" ffmpeg -f v4l2 -video_size 1920x1080 -i /dev/video0 "$outfile" || notify "High-def webcam recording failed"
}

askrecording() {
  choice=$(printf "screencast\nselected area\naudio\nwebcam\nwebcam (hi-def)\nkill recording" | $WMENU -p "Record what?" -l 6)
  case "$choice" in
  screencast) screencast ;;
  "selected area") video_selection ;;
  audio) audio_only ;;
  webcam) webcam ;;
  "webcam (hi-def)") webcam_hq ;;
  "kill recording") killrecording ;;
  *) return ;;
  esac
}

asktoend() {
  response=$(printf "No\nYes" | $WMENU -p "Recording still active. End it?") || return
  [ "$response" = "Yes" ] && killrecording
}

cleanup_record_state

case "$1" in
kill) killrecording ;;
*)
  if [ -f "$pidfile" ]; then
    asktoend
    exit 0
  fi
  askrecording
  ;;
esac
