#!/bin/sh
set -x

# Minimal wf-recorder wrapper for dmenu keybinds.
[ -e /proc/self/fd/0 ] || exec </dev/null

DMENU="${DMENU:-${WMENU:-wmenu -i}}"
RECORD_DIR="${VIDEO_RECORDINGS:-$HOME/Videos/screencasts}"
PIDFILE="/tmp/dmenurecord.pid"
OUTFILE="/tmp/dmenurecord.file"
ICONFILE="/tmp/recordingicon"
LOGFILE="${XDG_STATE_HOME:-$HOME/.local/state}/dmenurecord.log"
fallback_notice_shown=0

mkdir -p "$RECORD_DIR" "$(dirname "$LOGFILE")"

log() { printf '%s %s\n' "$(date '+%F %T')" "$*" >>"$LOGFILE"; }
notify() { command -v notify-send >/dev/null 2>&1 && notify-send "dmenurecord" "$1" || printf 'dmenurecord: %s\n' "$1" >&2; }

require() {
  command -v "$1" >/dev/null 2>&1 || {
    notify "Missing required tool: $1"
    return 1
  }
}

record_pid() { [ -s "$PIDFILE" ] && cat "$PIDFILE"; }
record_file() { [ -s "$OUTFILE" ] && cat "$OUTFILE"; }
clear_state() { rm -f "$PIDFILE" "$OUTFILE" "$ICONFILE"; }

wait_for_file() {
  file=$1
  [ -n "$file" ] || return 1
  # WAIT UP TO 10 seconds for file to be written
  for _ in $(seq 1 100); do
    [ -s "$file" ] && return 0
    sleep 0.1
  done
  return 1
}

record_active() {
  pid=$(record_pid) || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

set_state() {
  printf '%s\n' "$1" >"$PIDFILE"
  printf '%s\n' "$2" >"$OUTFILE"
  printf '%s\n' "$3" >"$ICONFILE"
}

timestamp() { date '+%y%m%d-%H%M-%S'; }

start_recorder() {
  icon=$1
  file=$2
  shift 2
  log "Starting: $* -> $file"
  (exec "$@" >>"$LOGFILE" 2>&1) &
  pid=$!
  sleep 0.2
  kill -0 "$pid" >/dev/null 2>&1 || {
    notify "Recorder exited immediately"
    clear_state
    return 1
  }
  set_state "$pid" "$file" "$icon"
  log "Recording pid=$pid file=$file"
}

start_wf() {
  mode=$1
  audio=$2 # with | without | auto
  require wf-recorder || return
  record_active && {
    notify "Recording already running"
    return
  }

  file="$RECORD_DIR/${mode}-$(timestamp).mkv"

  case "$mode" in
  screencast | screencast-noaudio)
    ;;
  region | region-noaudio)
    require slurp || return
    geom=$(slurp) || return
    [ -n "$geom" ] || return
    ;;
  *)
    return
    ;;
  esac

  build_and_start() {
    want_audio=$1 # yes | no
    icon=$2
    set -- wf-recorder
    case "$mode" in
    region | region-noaudio)
      set -- "$@" -g "$geom"
      ;;
    esac
    [ "$want_audio" = "yes" ] && set -- "$@" -a
    set -- "$@" -f "$file"
    start_recorder "$icon" "$file" "$@"
  }

  if [ "$audio" = "with" ]; then
    build_and_start yes "⏺️🎙️"
    return
  fi

  if [ "$audio" = "without" ]; then
    build_and_start no "⏺️"
    return
  fi

  # auto: try with audio, then fallback to video-only
  build_and_start yes "⏺️🎙️" && return

  [ $fallback_notice_shown -eq 0 ] && notify "Falling back to video-only (audio backend unavailable?)"
  fallback_notice_shown=1

  build_and_start no "⏺️"
}

start_audio_only() {
  require ffmpeg || return
  record_active && {
    notify "Recording already running"
    return
  }
  file="$RECORD_DIR/audio-$(timestamp).flac"
  start_recorder "🎙️" "$file" ffmpeg -f pulse -i default -c:a flac "$file" || notify "Audio recording failed"
}

start_webcam() {
  size=$1
  label=$2
  require ffmpeg || return
  record_active && {
    notify "Recording already running"
    return
  }
  file="$RECORD_DIR/${label}-$(timestamp).mkv"
  start_recorder "🎥" "$file" ffmpeg -f v4l2 -video_size "$size" -i /dev/video0 "$file" || notify "Webcam recording failed"
}

stop_recording() {
  pid=$(record_pid) || {
    notify "No recording in progress"
    return
  }
  file=$(record_file)

  # Tell wf-recorder to stop (expects SIGINT; fall back to SIGTERM)
  kill -INT "$pid" >/dev/null 2>&1 || kill -INT -- "-$pid" >/dev/null 2>&1 || kill -TERM "$pid" >/dev/null 2>&1 || kill -TERM -- "-$pid" >/dev/null 2>&1 || true

  # WAIT for recorder to finalize (UP TO 60 seconds)
  MAX_WAIT=600 # 600 * 0.1 = 60 seconds
  wait_count=0

  while kill -0 "$pid" >/dev/null 2>&1 && [ $wait_count -lt $MAX_WAIT ]; do
    sleep 0.1
    wait_count=$((wait_count + 1))
  done

  # If still alive after 60 seconds → kill it, but this almost never happens now
  if kill -0 "$pid" >/dev/null 2>&1; then
    kill -KILL "$pid" >/dev/null 2>&1 || kill -KILL -- "-$pid" >/dev/null 2>&1
  fi

  clear_state

  if wait_for_file "$file"; then
    notify "Saved recording to $file"
    log "Recording saved $file"
  else
    notify "Recording failed for $file"
    log "Recording empty $file"
  fi
}

prompt_menu() {
  printf '🖥️ Screen (full, audio)\n📐 Screen (region, audio)\n🖥️🔇 Screen (full, no audio)\n📐🔇 Screen (region, no audio)\n🎙️ Audio only\n🎥 Webcam\n🎥✨ Webcam (hi-def)\n⏹️ Stop\n' | $DMENU -p "Record?"
}

case "$1" in
start | menu | "")
  if record_active; then
    stop_recording
    exit
  fi
  choice=$(prompt_menu) || exit
  case "$choice" in
  "🖥️ Screen (full, audio)") start_wf screencast auto ;;
  "📐 Screen (region, audio)") start_wf region auto ;;
  "🖥️🔇 Screen (full, no audio)") start_wf screencast-noaudio without ;;
  "📐🔇 Screen (region, no audio)") start_wf region-noaudio without ;;
  "🎙️ Audio only") start_audio_only ;;
  "🎥 Webcam") start_webcam 640x480 webcam ;;
  "🎥✨ Webcam (hi-def)") start_webcam 1920x1080 webcam-hq ;;
  "⏹️ Stop") stop_recording ;;
  esac
  ;;
stop | kill)
  stop_recording
  ;;
status)
  record_active && [ -s "$ICONFILE" ] && tr -d '\n' <"$ICONFILE" && printf '\n'
  ;;
*)
  printf 'Usage: %s [start|stop|status]\n' "$0" >&2
  exit 1
  ;;
esac
