#!/bin/sh

# Small delay to avoid focus race when launched from menus (tweak if needed)
WAIT_BEFORE_SLURP="${WAIT_BEFORE_SLURP:-0.35}"

outdir="$HOME/Pictures/Screenshots"
mkdir -p "$outdir" || exit 1
stamp="$(date '+%y%m%d-%H%M-%S')"
out="$outdir/screenshot-$stamp.png"

mode="${1:-}"

# If no mode given, ask via wmenu
if [ -z "$mode" ]; then
  sel=$(printf "selected area\nfull screen\nselected area (copy)\nfull screen (copy)" | wmenu -i -l 4 -p "Screenshot which area?") || exit 0
  case "$sel" in
  "selected area") mode="area" ;;
  "full screen") mode="full" ;;
  "selected area (copy)") mode="area-copy" ;;
  "full screen (copy)") mode="full-copy" ;;
  *) exit 0 ;;
  esac
fi

case "$mode" in
area)
  sleep "$WAIT_BEFORE_SLURP"
  geo="$(slurp)" || exit 1
  [ -n "$geo" ] || exit 1
  grim -g "$geo" "$out" || exit 1
  ln -sf "$out" "$outdir/last.png"
  notify-send -a screenshot "Screenshot saved" "Left click to copy path/Right Click to open" || true
  ;;
full)
  grim "$out" || exit 1
  ln -sf "$out" "$outdir/last.png"
  notify-send -a screenshot "Screenshot saved" "Left click to copy path/Right Click to open" || true
  ;;
area-copy | copy-area)
  sleep "$WAIT_BEFORE_SLURP"
  geo="$(slurp)" || exit 1
  [ -n "$geo" ] || exit 1
  grim -g "$geo" - | wl-copy --type image/png
  notify-send -a screenshot "Screenshot copied to clipboard" || true
  ;;
full-copy | copy-full)
  grim - | wl-copy --type image/png
  notify-send -a screenshot "Screenshot copied to clipboard" || true
  ;;
*)
  printf 'usage: %s {area|full|area-copy|full-copy}\n' "$0" >&2
  exit 2
  ;;
esac
