#!/bin/sh

# System action helper using wmenu for Wayland sessions.
set -eu

export WM="dwl"

case "$(readlink -f /sbin/init)" in
*systemd*) ctl='systemctl' ;;
*) ctl='loginctl' ;;
esac

notify() {
  msg=$1
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "sysact" "$msg"
  else
    printf 'sysact: %s\n' "$msg" >&2
  fi
}

need_cmd() {
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      notify "Missing dependency: $cmd"
      exit 1
    fi
  done
}

need_cmd notify-send pstree wmenu "$ctl"

wmpid() {
  tree="$(pstree -ps $$)"
  tree="${tree#*$WM(}"
  printf '%s\n' "${tree%%)*}"
}

menu_items="🔒 lock
🚪 leave $WM
♻️ renew $WM
🐻 hibernate
🔃 reboot
🖥️ shutdown
💤 sleep"

choice="$(printf '%s\n' "$menu_items" | wmenu -i -p 'Action: ')"

case "$choice" in
'🔒 lock')
  need_cmd waylock
  waylock -z
  ;;
"🚪 leave $WM")
  kill -TERM "$(wmpid)"
  ;;
"♻️ renew $WM")
  pid="$(wmpid)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill -HUP "$pid"
  else
    notify "Unable to find running $WM process."
  fi
  ;;
'🐻 hibernate')
  need_cmd waylock "$ctl"
  waylock -z && "$ctl" hibernate -i
  ;;
'💤 sleep')
  need_cmd waylock "$ctl"
  waylock -z && "$ctl" suspend -i
  ;;
'🔃 reboot')
  "$ctl" reboot -i
  ;;
'🖥️ shutdown')
  "$ctl" poweroff -i
  ;;
*)
  exit 1
  ;;
esac
