#!/bin/sh

# System action helper using wmenu for Wayland sessions.
set -eu

export WM="dwl"
STOPFILE="${XDG_CACHE_HOME:-$HOME/.cache}/dwl-stop"

case "$(readlink -f /sbin/init)" in
*systemd*) ctl='systemctl' ;;
*) ctl='loginctl' ;;
esac

notify() {
  msg=$1
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "sysact" "$msg"
  else
    printf 'sysact: %s\n' "$msg" >&2
  fi
}

need_cmd() {
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      notify "Missing dependency: $cmd"
      exit 1
    fi
  done
}

need_cmd notify-send pstree wmenu "$ctl"

wmpid() {
  tree="$(pstree -ps $$)"
  tree="${tree#*$WM\(}"
  printf '%s\n' "${tree%%\)*}"
}

menu_items="🔒 lock
🚪 leave $WM
♻️ renew $WM
🐻 hibernate
🔃 reboot
🖥️ shutdown
💤 sleep"

choice="$(printf '%s\n' "$menu_items" | wmenu -i -p 'Action: ')"

case "$choice" in
'🔒 lock')
  need_cmd waylock
  waylock
  ;;
"🚪 leave $WM")
  need_cmd waylock
  pid="$(wmpid)"
  mkdir -p "$(dirname "$STOPFILE")"
  : >"$STOPFILE"
  kill -TERM "$pid"
  ;;
"♻️ renew $WM")
  pid="$(wmpid)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill -USR1 "$pid"
  else
    notify "Unable to find running $WM process."
  fi
  ;;
'🐻 hibernate')
  $ctl hibernate -i
  need_cmd waylock
  waylock
  ;;
'💤 sleep')
  $ctl suspend -i
  need_cmd waylock
  waylock
  ;;
'🔃 reboot') $ctl reboot -i ;;
'🖥️shutdown') $ctl poweroff -i ;;
# '📺 display off') xset dpms force off ;;
*) exit 1 ;;
esac
